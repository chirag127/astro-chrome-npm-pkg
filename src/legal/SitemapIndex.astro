---
/*
 * SitemapIndex.astro — sitemap index page linking to per-app sitemaps.
 *
 * Two modes:
 *   1. Default — renders a human-readable HTML page listing all family-app sitemaps.
 *   2. format="xml" — renders a sitemap-index XML document (mount with
 *      `sitemap-index.xml.astro` and set Astro.response.headers / use a JSON
 *      content-type approach in the consuming app).
 *
 * `apps` prop is an array of `{ name, url }`. If omitted, only this app is listed.
 */
interface AppEntry {
  name: string
  url: string  // base URL of the app, e.g. "https://oriz.in"
}
interface Props {
  appName: string
  appDomain: string
  apps?: AppEntry[]
  format?: 'html' | 'xml'
  lastUpdated?: string
}
const { appName, appDomain, apps = [], format = 'html', lastUpdated } = Astro.props
const allApps: AppEntry[] = apps.length > 0 ? apps : [{ name: appName, url: `https://${appDomain}` }]
---

{format === 'xml' ? (
  <Fragment set:html={`<?xml version="1.0" encoding="UTF-8"?>
<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
${allApps.map(a => `  <sitemap><loc>${a.url}/sitemap.xml</loc>${lastUpdated ? `<lastmod>${lastUpdated}</lastmod>` : ''}</sitemap>`).join('\n')}
</sitemapindex>`} />
) : (
  <article class="legal-page legal-sitemap">
    <header class="legal-head">
      <p class="eyebrow"><a href="/">{appName}</a> / sitemap</p>
      <h1>Sitemap Index</h1>
      <p class="lede">Per-app sitemaps for every site in the family. Machine-readable XML at <a href="/sitemap.xml">/sitemap.xml</a>.</p>
    </header>

    <section class="legal-body">
      <ul class="sitemap-list">
        {allApps.map((a) => (
          <li>
            <a href={`${a.url}/sitemap.xml`}><strong>{a.name}</strong></a>
            <span class="domain"> · <a href={a.url}>{a.url.replace(/^https?:\/\//, '')}</a></span>
          </li>
        ))}
      </ul>

      <p class="meta">Updated automatically on every deploy. {lastUpdated && `Last verified · ${lastUpdated}.`}</p>

      <slot />
    </section>
  </article>
)}

<style>
  .legal-page { max-width: 72ch; margin-inline: auto; padding-block: 2rem; }
  .legal-head { border-bottom: 1px solid var(--rule, #e5e5e5); padding-bottom: 1.5rem; margin-bottom: 2rem; }
  .legal-head h1 { font-family: var(--font-display, Georgia, serif); font-size: clamp(2rem, 4vw, 3rem); margin: 0.25rem 0; }
  .eyebrow { font-size: 0.875rem; color: var(--ink-mute, #666); margin: 0; }
  .eyebrow a { color: inherit; }
  .lede { font-size: 1.125rem; color: color-mix(in oklab, var(--ink, #111) 90%, var(--paper, #fff)); }
  .sitemap-list { list-style: none; padding: 0; }
  .sitemap-list li { padding-block: 0.5rem; border-bottom: 1px solid var(--rule, #e5e5e5); }
  .domain { color: var(--ink-mute, #666); font-size: 0.875rem; }
  .meta { font-size: 0.875rem; color: var(--ink-mute, #666); margin-top: 2rem; }
</style>
